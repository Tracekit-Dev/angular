{
  "name": "@tracekit/angular",
  "version": "0.1.1",
  "description": "TraceKit Angular Integration - Error capture and navigation breadcrumbs for Angular 17+",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "dev": "tsup --watch"
  },
  "peerDependencies": {
    "@angular/core": ">=17.0.0",
    "@angular/router": ">=17.0.0",
    "@tracekit/browser": "^0.1.1"
  },
  "devDependencies": {
    "@angular/core": "^19.0.0",
    "@angular/router": "^19.0.0",
    "@tracekit/browser": "^0.1.1",
    "jsdom": "^28.0.0",
    "rxjs": "^7.8.0",
    "tsup": "^8.0.0",
    "typescript": "^5.3.0",
    "vitest": "^3.0.0"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Tracekit-Dev/angular"
  },
  "keywords": [
    "tracekit",
    "angular",
    "error-tracking",
    "observability",
    "breadcrumbs"
  ]
}
